# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ── Infrastructure ───────────────────────────────────────────────────────────
# Hostname or IP of the Docker host (used in Gitea/Woodpecker external URLs)
DS1_HOST=ds1
POSTGRES_PASSWORD=changeme

# ── LLM ─────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.1:8b

# ── Gitea ────────────────────────────────────────────────────────────────────
# Admin user created automatically on first start by the gitea-init service
GITEA_ADMIN_USER=platform
GITEA_ADMIN_PASS=changeme
GITEA_ADMIN_EMAIL=admin@platform.local

# ── Woodpecker CI ─────────────────────────────────────────────────────────────
# OAuth2 app credentials — see README step 4 (one-time manual setup in Gitea UI)
WOODPECKER_GITEA_CLIENT=
WOODPECKER_GITEA_SECRET=
# Shared secret between woodpecker-server and woodpecker-agent
WOODPECKER_AGENT_SECRET=changeme
